# Copy to .env and adjust. Loaded by dotenv in src/app.js

# --- CloudAudit platform IAM (STS into customer accounts) ---
# After running scripts/aws/create-cloudaudit-platform-roles.sh in CloudShell, paste the ARNs:
#
# CLOUDAUDIT_PLATFORM_MODE=production
# CLOUDAUDIT_PLATFORM_ROLE_ARN_PRODUCTION=arn:aws:iam::123456789012:role/CloudAuditPlatformRoleProduction
# CLOUDAUDIT_PLATFORM_ROLE_ARN_DEVELOPMENT=arn:aws:iam::123456789012:role/CloudAuditPlatformRoleDevelopment
#
# Local API: omit CLOUDAUDIT_PLATFORM_MODE to default to the *development* platform role (unless NODE_ENV=production).
# Or set explicitly:
# CLOUDAUDIT_PLATFORM_MODE=development
# CLOUDAUDIT_PLATFORM_MODE=production
#
# The API assumes this role using your default AWS credentials (e.g. aws sso login).
# Re-run scripts/aws/create-cloudaudit-platform-roles.sh from the same SSO session; it auto-adds
# your SSO role to the dev platform role trust (or set DEV_ASSUMER_ARNS to that IAM role ARN).
#
# Alternative: single-legacy ARN (customer trust lists only one principal):
# CLOUDAUDIT_PLATFORM_ROLE_ARN=arn:aws:iam::123456789012:role/MyRole
#
# Or build ARNs from account + names (same account for both):
# CLOUDAUDIT_PLATFORM_AWS_ACCOUNT_ID=123456789012
# CLOUDAUDIT_PLATFORM_ROLE_NAME_PRODUCTION=CloudAuditPlatformRoleProduction
# CLOUDAUDIT_PLATFORM_ROLE_NAME_DEVELOPMENT=CloudAuditPlatformRoleDevelopment

NODE_ENV=development
PORT=3000

# --- Notifications ---
# Enable/disable Slack notifications for weekly reports and anomaly alerts
SLACK_NOTIFICATIONS_ENABLED=false
# Slack incoming webhook URL (create in your Slack app settings)
SLACK_WEBHOOK_URL=

# --- Email notifications (AWS SES) ---
# Must be the string `true` for anomaly + weekly emails. Verification/password emails always use SES and ignore this.
EMAIL_NOTIFICATIONS_ENABLED=false
# Comma-separated list of recipients for automated notifications.
# Example: ops@example.com,team@example.com
NOTIFICATIONS_EMAIL_TO=
