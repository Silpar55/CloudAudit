# Copy to `.env` and fill in real values. Never commit `.env`.
# This file lists every variable the backend may read; optional ones can stay empty.

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- PostgreSQL (pg module uses these standard names) ---
PGUSER=cloudaudit
PGPASSWORD=change-me
PGHOST=localhost
PGPORT=5432
PGDATABASE=cloudaudit

# --- Auth (JWT access + refresh) ---
JWT_SECRET=change-me-long-random-string
JWT_REFRESH_SECRET=change-me-different-long-random-string

# --- CORS / links in emails ---
FRONTEND_URL=http://localhost:5173

# --- AWS region (SES, STS, SDK default chain on EC2 uses instance/task role) ---
AWS_REGION=us-east-1

# --- SES ---
SES_SENDER_EMAIL=verified-sender@example.com

# --- Email notifications (SES); verification emails still use SES when configured ---
EMAIL_NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_EMAIL_TO=

# --- ML service URL ---
# Local Docker ML: http://127.0.0.1:5001/api/ml/analyze?version=2
# Root docker-compose.prod.yml sets http://ml:5000/... — you can omit this on EC2 when using that compose file.
ML_SERVICE_URL=

# --- Lyzr (optional AI recommendations) ---
LYZR_API_URL=
LYZR_API_KEY=
LYZR_AGENT_ID=

# --- CloudAudit platform IAM (STS into customer accounts) ---
# See scripts/aws/create-cloudaudit-platform-roles.sh
CLOUDAUDIT_PLATFORM_MODE=production
CLOUDAUDIT_PLATFORM_ROLE_ARN_PRODUCTION=arn:aws:iam::123456789012:role/CloudAuditPlatformRoleProduction
CLOUDAUDIT_PLATFORM_ROLE_ARN_DEVELOPMENT=arn:aws:iam::123456789012:role/CloudAuditPlatformRoleDevelopment
# Optional legacy single ARN:
# CLOUDAUDIT_PLATFORM_ROLE_ARN=
# Optional: build ARNs from account + role names
# CLOUDAUDIT_PLATFORM_AWS_ACCOUNT_ID=123456789012
# CLOUDAUDIT_PLATFORM_ROLE_NAME_PRODUCTION=CloudAuditPlatformRoleProduction
# CLOUDAUDIT_PLATFORM_ROLE_NAME_DEVELOPMENT=CloudAuditPlatformRoleDevelopment

# --- Slack (optional) ---
SLACK_NOTIFICATIONS_ENABLED=false
SLACK_WEBHOOK_URL=

# --- Tests only ---
# SKIP_PLATFORM_ASSUME_ROLE=true
