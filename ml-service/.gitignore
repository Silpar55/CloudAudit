# =============================================================
# CloudAudit ML Service — .gitignore
# =============================================================

# Virtual environment
.venv/
venv/
env/

# Environment variables — never commit secrets
.env

# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/

# ML model artifacts — serialized models can be large, use model registry instead
*.pkl
*.joblib
*.h5

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp