# Save as ml-service/.env on the EC2 host.
# Must use the SAME database as the backend (RDS).
# Copy up: scp -i your.pem ml-service.env.template ec2-user@YOUR_IP:~/CloudAudit/ml-service/.env

DATABASE_URL=postgresql://YOUR_RDS_USER:YOUR_RDS_PASSWORD@your-db.xxxxx.us-east-1.rds.amazonaws.com:5432/cloudaudit

# Optional
# FLASK_ENV=production
# MODEL_VERSION=isolation-forest-v1
